    <decisions>
        <name>Check_Discount</name>
        <label>Check_Discount</label>
        <locationX>0</locationX>
        <locationY>0</locationY>
        <defaultConnector>
            <targetReference>Loop_Through_QLIs</targetReference>
        </defaultConnector>
        <defaultConnectorLabel>Default Outcome</defaultConnectorLabel>
        <rules>
            <name>Too_High</name>
            <conditionLogic>and</conditionLogic>
            <conditions>
                <leftValueReference>Loop_Through_QLIs.Offered_Discount__c</leftValueReference>
                <operator>GreaterThan</operator>
                <rightValue>
