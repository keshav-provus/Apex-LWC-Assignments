                </rightValue>
            </conditions>
            <conditions>
                <leftValueReference>Loop_Through_QLIs.Category__r.Max_Discount__c</leftValueReference>
                <operator>IsNull</operator>
                <rightValue>
                    <booleanValue>false</booleanValue>
                </rightValue>
            </conditions>
            <connector>
                <targetReference>Set_Approval_True</targetReference>
            </connector>
            <label>Too_High</label>
        </rules>
